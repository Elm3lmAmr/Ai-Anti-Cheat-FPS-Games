<Window x:Class="XonticAntiCheatFinal.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Report Player" 
        Height="400" Width="500"
        WindowStartupLocation="CenterOwner">

    <Grid Background="#1E1E1E" Margin="20">
        <StackPanel>
            <TextBlock Text="Report Player" 
                      FontSize="20" 
                      Foreground="White"
                      Margin="0 0 0 20"/>

            <!-- Reported Player -->
            <TextBlock Text="Reported Player Username" 
                      Foreground="#CCCCCC"
                      Margin="0 0 0 5"/>
            <TextBox x:Name="txtReportedPlayer" 
                    Height="30"
                    Background="#333333"
                    Foreground="White"
                    BorderBrush="#555555"
                    Margin="0 0 0 15"/>

            <!-- Cheat Type -->
            <TextBlock Text="Cheat Type" 
                      Foreground="#CCCCCC"
                      Margin="0 0 0 5"/>
            <ComboBox x:Name="cmbCheatType"
                     Height="30"
                     Background="#333333"
                     Foreground="White"
                     BorderBrush="#555555"
                     Margin="0 0 0 15">
                <ComboBoxItem Content="Aimbot"/>
                <ComboBoxItem Content="Wallhack"/>
                <ComboBoxItem Content="Speed Hack"/>
                <ComboBoxItem Content="ESP"/>
                <ComboBoxItem Content="Other"/>
            </ComboBox>

            <!-- Description -->
            <TextBlock Text="Description (Optional)" 
                      Foreground="#CCCCCC"
                      Margin="0 0 0 5"/>
            <TextBox x:Name="txtDescription"
                    Height="60"
                    Background="#333333"
                    Foreground="White"
                    BorderBrush="#555555"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Margin="0 0 0 20"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                       Width="80"
                       Height="30"
                       Background="#555555"
                       Foreground="White"
                       Margin="0 0 10 0"
                       Click="BtnCancel_Click"/>

                <Button x:Name="btnSubmit"
                       Content="Submit Report"
                       Width="120"
                       Height="30"
                       Background="#007ACC"
                       Foreground="White"
                       FontWeight="Bold"
                       Click="BtnSubmit_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>