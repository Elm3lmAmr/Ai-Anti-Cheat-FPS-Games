<Window x:Class="XonticAntiCheatFinal.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xontic Anti-Cheat - Login" 
        Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#0F172A">
        <!-- Header -->
        <Border Background="#1E293B" Height="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🎮 XONTIC" 
                          FontSize="28" 
                          FontWeight="Bold"
                          Foreground="#60A5FA"/>
                <TextBlock Text="Anti-Cheat System"
                          FontSize="14"
                          Foreground="#94A3B8"
                          Margin="0 5 0 0"/>
            </StackPanel>
        </Border>

        <!-- Login Form -->
        <Border Background="#1E293B" 
                CornerRadius="10"
                Margin="40"
                VerticalAlignment="Center"
                Padding="25">
            <StackPanel>
                <TextBlock Text="Welcome Back" 
                          FontSize="18" 
                          Foreground="White"
                          Margin="0 0 0 20"/>

                <!-- Username -->
                <TextBlock Text="Username" 
                          Foreground="#94A3B8"
                          Margin="0 0 0 5"/>
                <TextBox x:Name="txtUsername" 
                        Height="35"
                        Background="#334155"
                        Foreground="White"
                        BorderBrush="#475569"
                        FontSize="14"
                        Margin="0 0 0 15"/>

                <!-- Password -->
                <TextBlock Text="Password" 
                          Foreground="#94A3B8"
                          Margin="0 0 0 5"/>
                <PasswordBox x:Name="txtPassword" 
                           Height="35"
                           Background="#334155"
                           BorderBrush="#475569"
                           FontSize="14"
                           Margin="0 0 0 20"/>

                <!-- Remember Me -->
                <CheckBox x:Name="chkRememberMe" 
                         Content="Remember me"
                         Foreground="#94A3B8"
                         Margin="0 0 0 20"/>

                <!-- Login Button -->
                <Button x:Name="btnLogin"
                        Content="SIGN IN"
                        Height="40"
                        Background="#3B82F6"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="14"
                        BorderThickness="0"
                        BorderBrush="#2563EB"
                        Cursor="Hand"
                        Click="BtnLogin_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <!-- Register Link -->
                <StackPanel Orientation="Horizontal" 
                           HorizontalAlignment="Center"
                           Margin="0 20 0 0">
                    <TextBlock Text="New to Xontic? " 
                              Foreground="#94A3B8"/>
                    <TextBlock x:Name="txtSignUp" 
                              Text="Create Account"
                              Foreground="#60A5FA"
                              Cursor="Hand"
                              FontWeight="SemiBold"
                              MouseDown="TxtSignUp_MouseDown"/>
                </StackPanel>

                <!-- Error Message -->
                <Border x:Name="errorBorder"
                        Background="#7F1D1D"
                        CornerRadius="6"
                        Padding="10"
                        Margin="0 15 0 0"
                        Visibility="Collapsed">
                    <TextBlock x:Name="txtError"
                              Foreground="#FCA5A5"
                              TextWrapping="Wrap"
                              TextAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Border Background="#1E293B" VerticalAlignment="Bottom" Height="40">
            <TextBlock Text="v1.0.0 | Secure Gaming Environment"
                      Foreground="#64748B"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>