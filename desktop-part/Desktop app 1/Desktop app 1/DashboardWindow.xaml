<Window x:Class="XonticAntiCheatFinal.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard - Xontic Anti-Cheat"
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

	<Window.Resources>
		<!-- ستايل البطاقات -->
		<Style x:Key="StatCard" TargetType="Border">
			<Setter Property="Background" Value="#1E293B"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="20"/>
			<Setter Property="Margin" Value="5"/>
			<Setter Property="Effect">
				<Setter.Value>
					<DropShadowEffect BlurRadius="10" Opacity="0.2"/>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ستايل الأزرار الجانبية -->
		<Style x:Key="SidebarButton" TargetType="Button">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Foreground" Value="#94A3B8"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="HorizontalContentAlignment" Value="Left"/>
			<Setter Property="Padding" Value="15 12"/>
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#334155"/>
					<Setter Property="Foreground" Value="#FFFFFF"/>
				</Trigger>
			</Style.Triggers>
		</Style>
	</Window.Resources>

	<Grid Background="#0F172A">
		<!-- الهيكل الرئيسي -->
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="260"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<!-- ===== السايدبار ===== -->
		<Border Grid.Column="0" Background="#1E293B">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<!-- معلومات المستخدم -->
				<Border Grid.Row="0" Background="#0F172A" Padding="25">
					<StackPanel>
						<!-- صورة المستخدم -->
						<Border Width="70" Height="70"
                                Background="#3B82F6"
                                CornerRadius="35"
                                HorizontalAlignment="Center"
                                Margin="0 0 0 15">
							<TextBlock Text="U"
                                      Foreground="White"
                                      FontSize="24"
                                      FontWeight="Bold"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
						</Border>

						<!-- الاسم والمستوى -->
						<TextBlock x:Name="txtUsername"
                                 Text="Loading..."
                                 Foreground="White"
                                 FontSize="16"
                                 FontWeight="Bold"
                                 HorizontalAlignment="Center"/>

						<TextBlock Text="Player • Level 25"
                                 Foreground="#60A5FA"
                                 FontSize="12"
                                 HorizontalAlignment="Center"
                                 Margin="0 5 0 0"/>

						<!-- Risk Indicator -->
						<Border Background="#1E293B"
                                CornerRadius="15"
                                Padding="8 4"
                                HorizontalAlignment="Center"
                                Margin="0 10 0 0">
							<StackPanel Orientation="Horizontal">
								<Ellipse Width="8" Height="8"
                                         Fill="#10B981"
                                         Margin="0 0 6 0"/>
								<TextBlock Text="Low Risk"
                                         Foreground="#10B981"
                                         FontSize="12"/>
							</StackPanel>
						</Border>
					</StackPanel>
				</Border>

				<!-- القائمة الجانبية -->
				<StackPanel Grid.Row="1" Margin="15 20">
                    <Button Content="🎮 Launch Game"
                            Style="{StaticResource SidebarButton}"
                            Click="BtnReports_Click"/>

                    <Button Content="⚠️ Reports"
                           Style="{StaticResource SidebarButton}"
                           Click="BtnReports_Click"/>

					<Button Content="🚨 New Report"
                           Style="{StaticResource SidebarButton}"
                           Background="#3B82F6"
                           Foreground="White"
                           Margin="0 10 0 0"
                           Click="BtnReportPlayer_Click">
						<Button.Resources>
							<Style TargetType="Border">
								<Setter Property="CornerRadius" Value="6"/>
							</Style>
						</Button.Resources>
					</Button>

					<Separator Background="#334155" Margin="0 20"/>

					<Button Content="⚙️ Settings"
                           Style="{StaticResource SidebarButton}"/>

					<Button Content="❓ Help"
                           Style="{StaticResource SidebarButton}"/>
				</StackPanel>

				<!-- زر الخروج -->
				<Border Grid.Row="2" Padding="15">
					<Button Content="Logout"
                           Background="#EF4444"
                           Foreground="White"
                           Height="40"
                           FontWeight="SemiBold"
                           BorderThickness="0"
                           Cursor="Hand"
                           Click="BtnLogout_Click">
						<Button.Resources>
							<Style TargetType="Border">
								<Setter Property="CornerRadius" Value="6"/>
							</Style>
						</Button.Resources>
					</Button>
				</Border>
			</Grid>
		</Border>

		<!-- ===== المحتوى الرئيسي ===== -->
		<ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
			<StackPanel Margin="25">
				<!-- العنوان والترحيب -->
				<StackPanel Margin="0 0 0 20">
					<TextBlock Text="Welcome back,"
                             Foreground="#94A3B8"
                             FontSize="16"/>
					<TextBlock x:Name="txtWelcomeUser"
                             Text="Player"
                             Foreground="White"
                             FontSize="28"
                             FontWeight="Bold"/>
				</StackPanel>

				<!-- بطاقات الإحصائيات -->
                <TextBlock Text="Dashboard"
                         Foreground="White"
                         FontSize="18"
                         FontWeight="SemiBold"
                         Margin="0 0 0 15"/>

                <WrapPanel>
                    <!-- بطاقة المباريات -->
                    <Border Style="{StaticResource StatCard}" Width="220">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🎮" FontSize="20" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="128" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Total Games"
                                     Foreground="#94A3B8"
                                     Margin="0 8 0 0"/>
                            <ProgressBar Value="75"
                                       Maximum="100"
                                       Height="6"
                                       Margin="0 10 0 0"
                                       Background="#334155">
                                <ProgressBar.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3B82F6" Offset="0"/>
                                        <GradientStop Color="#60A5FA" Offset="1"/>
                                    </LinearGradientBrush>
                                </ProgressBar.Foreground>
                            </ProgressBar>
                        </StackPanel>
                    </Border>

                    <!-- بطاقة الفوز -->
                    <Border Style="{StaticResource StatCard}" Width="220">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🏆" FontSize="20" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="64%" FontSize="24" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Win Rate"
                                     Foreground="#94A3B8"
                                     Margin="0 8 0 0"/>
                            <TextBlock Text="+5.2% this month"
                                     Foreground="#10B981"
                                     FontSize="12"
                                     Margin="0 5 0 0"/>
                        </StackPanel>
                    </Border>

                    <!-- بطاقة K/D -->
                    <Border Style="{StaticResource StatCard}" Width="220">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🎯" FontSize="20" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="2.8" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="K/D Ratio"
                                     Foreground="#94A3B8"
                                     Margin="0 8 0 0"/>
                            <TextBlock Text="Top 15% of players"
                                     Foreground="#94A3B8"
                                     FontSize="12"
                                     Margin="0 5 0 0"/>
                        </StackPanel>
                    </Border>

                    <!-- بطاقة K/D -->
                    <Border Style="{StaticResource StatCard}" Width="220">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🎯" FontSize="20" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="2.8" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Headshot ratio"
                 Foreground="#94A3B8"
                 Margin="0 8 0 0"/>
                            <TextBlock Text="Top 15% of players"
                 Foreground="#94A3B8"
                 FontSize="12"
                 Margin="0 5 0 0"/>
                        </StackPanel>
                    </Border>

                    <!-- بطاقة التقارير -->
                    <Border Style="{StaticResource StatCard}" Width="220">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📋" FontSize="20" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="3" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Active Reports"
                                     Foreground="#94A3B8"
                                     Margin="0 8 0 0"/>
                            <Button Content="View All"
                                   Background="#334155"
                                   Foreground="#94A3B8"
                                   Height="28"
                                   FontSize="11"
                                   Margin="0 10 0 0"
                                   Padding="10 0"
                                   BorderThickness="0"
                                   Cursor="Hand"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                
                
                
                
                
                
                
                
                
                
                
                <!-- Footer -->
				<TextBlock Text="© 2024 Xontic Anti-Cheat System. All rights reserved."
                         Foreground="#64748B"
                         FontSize="12"
                         HorizontalAlignment="Center"
                         Margin="0 30 0 20"/>
			</StackPanel>
		</ScrollViewer>
	</Grid>
</Window>